  "cells": [
    {
      "cell_type": "markdown",
      "source": "## Matrices",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "A: matrix([1, 2, 3], [4, 5, 6], [7, 8, 10])",
      "metadata": {},
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": "Determinant",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "determinant(A)",
      "metadata": {},
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": "Inverse",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "invert(A)",
      "metadata": {},
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": "Verify: $A \\cdot A^{-1} = I$",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "ratsimp(A . invert(A))",
      "metadata": {},
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": "Transpose",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "transpose(A)",
      "metadata": {},
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": "## Eigenvalues",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "eigenvalues(matrix([2, 1], [1, 2]))",
      "metadata": {},
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": "Characteristic polynomial",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "charpoly(matrix([2, 1], [1, 2]), lambda)",
      "metadata": {},
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": "## Linear Systems\n\nSolve $x + 2y = 5$, $3x + 4y = 11$",
      "metadata": {}
    },
    {
      "cell_type": "code",
      "source": "linsolve([x + 2*y = 5, 3*x + 4*y = 11], [x, y])",
      "metadata": {},
      "execution_count": null,
      "outputs": []
    },
